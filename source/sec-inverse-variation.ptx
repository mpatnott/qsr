  <activity xml:id="a-logs-and-negatives">
    <introduction>
        <p>
            Let's stretch our understanding of negative exponents and logarithms! Evaluate each of the logs below <alert>without using a calculator</alert>. You can check your answer with a calculator, but should first find them without one.
        </p>
    </introduction>
    <!-- <task workspace="0.5in">
        <statement>
            <p>
                <m>\log_2\left(\sqrt{2}\right)</m>
            </p>
        </statement>
    </task> -->
    <task workspace="0.5in">
        <statement>
            <p>
                <m>\log_2\left(\frac{1}{2}\right)</m>
            </p>
        </statement>
    </task>
    <task workspace="0.5in">
        <statement>
            <p>
                <m>\log_{10}\left(\frac{1}{100}\right)</m>
            </p>
        </statement>
    </task>
    <task workspace="0.5in">
        <statement>
            <p>
                <m>\log_{9}\left(\frac{1}{27}\right)</m>
            </p>
        </statement>
    </task>
    <task workspace="0.5in">
        <statement>
            <p>
                <alert>Challenge:</alert> Find <m>b</m> so that <m>\log_b\left(\frac{1}{125}\right) = -3</m>
            </p>
        </statement>
    </task>
  </activity>
</section>